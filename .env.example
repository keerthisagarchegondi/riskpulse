# =============================================================================
# RiskPulse - Fraud Analytics & Risk Intelligence Platform
# Environment Configuration
# =============================================================================

# Application
APP_NAME=riskpulse
APP_ENV=development
APP_DEBUG=true
APP_LOG_LEVEL=DEBUG
APP_SECRET_KEY=change-me-in-production

# API
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4
API_KEY=dev-api-key-change-in-production

# PostgreSQL
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=riskpulse
POSTGRES_USER=riskpulse
POSTGRES_PASSWORD=riskpulse_dev_password
POSTGRES_POOL_SIZE=20
POSTGRES_MAX_OVERFLOW=10

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_CONSUMER_GROUP=riskpulse-consumer
KAFKA_AUTO_OFFSET_RESET=earliest
KAFKA_SCHEMA_REGISTRY_URL=http://localhost:8081

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# Snowflake
SNOWFLAKE_ACCOUNT=your_account
SNOWFLAKE_USER=your_user
SNOWFLAKE_PASSWORD=your_password
SNOWFLAKE_DATABASE=RISKPULSE
SNOWFLAKE_WAREHOUSE=COMPUTE_WH
SNOWFLAKE_SCHEMA=RAW
SNOWFLAKE_ROLE=SYSADMIN

# AWS
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
AWS_S3_BUCKET_RAW=riskpulse-dev-raw
AWS_S3_BUCKET_PROCESSED=riskpulse-dev-processed
AWS_S3_BUCKET_MODELS=riskpulse-dev-models

# CloudWatch
CLOUDWATCH_LOG_GROUP=/riskpulse/dev
CLOUDWATCH_METRICS_NAMESPACE=RiskPulse/Dev

# Airflow
AIRFLOW__CORE__EXECUTOR=LocalExecutor
AIRFLOW__CORE__SQL_ALCHEMY_CONN=postgresql+psycopg2://airflow:airflow@localhost:5432/airflow
AIRFLOW__CORE__FERNET_KEY=change-me-generate-with-python
AIRFLOW__WEBSERVER__SECRET_KEY=change-me-in-production

# Model Configuration
MODEL_VERSION=v1.0.0
MODEL_ANOMALY_CONTAMINATION=0.01
MODEL_RISK_THRESHOLD_HIGH=0.8
MODEL_RISK_THRESHOLD_CRITICAL=0.95

# Alerting
ALERT_EMAIL_SENDER=alerts@riskpulse.dev
ALERT_WEBHOOK_URL=https://hooks.slack.com/services/your/webhook
ALERT_ESCALATION_TIMEOUT_MINUTES=15

# Encryption
ENCRYPTION_KEY=generate-32-byte-key-for-production
